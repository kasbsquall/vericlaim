# ============================================================
# VERICLAIM — Environment variables
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# ============================================================

# --- Database ---
# Local dev (docker-compose): host port 5434, DB `vericlaim` (sibling to Recourse on 5433).
# SQLAlchemy async needs the `+asyncpg` driver suffix.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5434/vericlaim

# --- LLMs (reused from Recourse) ---
# AI/ML API — powers Blake, Morgan, Sam (OpenAI-compatible)
AIMLAPI_API_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_MODEL=gpt-4o

# Featherless — powers Alex, the Devil's Advocate (OpenAI-compatible)
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=NousResearch/Hermes-2-Pro-Llama-3-8B

# --- CROO Agent Protocol (CAP) ---
# Real env model (per docs.croo.network): each agent gets a CROO_SDK_KEY (croo_sk_...)
# from the dashboard at agent.croo.network. Registration auto-deploys an AA wallet and
# Agent DID; gas is sponsored by CROO — NO wallet private key is needed.
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
BASE_RPC_URL=https://mainnet.base.org

# VeriClaim's own service SDK key (the main adjudication agent)
CROO_SDK_KEY=

# Helper-agent SDK keys (each is a separately-registered CAP agent → satisfies the
# "≥3 unique counterparty agents" requirement). They call VeriClaim via CAP.
CLAIM_INGESTER_SDK_KEY=
REPORT_EXPORTER_SDK_KEY=
POLICY_EXTRACTOR_SDK_KEY=

# --- App config ---
ENVIRONMENT=development
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
